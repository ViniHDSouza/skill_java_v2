## Retry com Backoff Exponencial via DLX

```java
@Component
@RequiredArgsConstructor
@Slf4j
public class OrderMessageConsumer {

    private final OrderService orderService;
    private final RabbitTemplate rabbitTemplate;

    private static final int MAX_RETRIES = 3;
    private static final String RETRY_COUNT_HEADER = "x-retry-count";

    @RabbitListener(queues = RabbitMQConfig.ORDERS_QUEUE)
    public void consume(
            Message message,
            Channel channel,
            @Header(AmqpHeaders.DELIVERY_TAG) long deliveryTag) throws IOException {

        String body = new String(message.getBody(), StandardCharsets.UTF_8);
        int retryCount = getRetryCount(message);

        log.info("Processando mensagem: deliveryTag={}, retryCount={}", deliveryTag, retryCount);

        try {
            OrderCreatedEvent event = objectMapper.readValue(body, OrderCreatedEvent.class);
            orderService.processOrderCreated(event);
            channel.basicAck(deliveryTag, false);  // sucesso — remove da fila
            log.info("Mensagem processada com sucesso: deliveryTag={}", deliveryTag);

        } catch (NonRetryableException e) {
            log.error("Erro não retriável — enviando direto para DLQ: {}", e.getMessage());
            channel.basicNack(deliveryTag, false, false);  // false = não reencfileira → vai para DLX

        } catch (Exception e) {
            if (retryCount >= MAX_RETRIES) {
                log.error("Máximo de retries atingido ({}) — enviando para DLQ", MAX_RETRIES, e);
                channel.basicNack(deliveryTag, false, false);  // vai para DLQ
            } else {
                log.warn("Erro retriável (tentativa {}/{}) — reenviando com delay",
                    retryCount + 1, MAX_RETRIES, e);
                channel.basicAck(deliveryTag, false);  // ack para remover da fila atual
                requeueWithDelay(message, retryCount + 1);  // envia para retry queue
            }
        }
    }

    private void requeueWithDelay(Message originalMessage, int retryCount) {
        MessageProperties props = new MessageProperties();
        props.getHeaders().putAll(originalMessage.getMessageProperties().getHeaders());
        props.getHeaders().put(RETRY_COUNT_HEADER, retryCount);
        props.setContentType(MessageProperties.CONTENT_TYPE_JSON);

        Message retryMessage = new Message(originalMessage.getBody(), props);
        // Envia para retry queue (que tem TTL e redireciona de volta para fila principal)
        rabbitTemplate.send(
            RabbitMQConfig.ORDERS_RETRY_EXCHANGE,
            RabbitMQConfig.ORDERS_RETRY_QUEUE,
            retryMessage
        );
    }

    private int getRetryCount(Message message) {
        Object count = message.getMessageProperties().getHeaders().get(RETRY_COUNT_HEADER);
        return count == null ? 0 : (Integer) count;
    }

    // Consumer da DLQ — processa mensagens que falharam definitivamente
    @RabbitListener(queues = RabbitMQConfig.ORDERS_DLQ)
    public void consumeDlq(
            Message message,
            Channel channel,
            @Header(AmqpHeaders.DELIVERY_TAG) long deliveryTag) throws IOException {

        log.error("Mensagem na DLQ — ação manual necessária: {}",
            new String(message.getBody(), StandardCharsets.UTF_8));

        // Salvar para análise / alertar time de operações
        dlqEventRepository.save(DlqEvent.from(message));
        channel.basicAck(deliveryTag, false);
    }
}
```

