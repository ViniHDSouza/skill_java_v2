## Publisher Confirms — Garantia de Entrega

```java
@Service
@RequiredArgsConstructor
@Slf4j
public class OrderEventPublisher {

    private final RabbitTemplate rabbitTemplate;

    @PostConstruct
    public void configure() {
        // Confirma que mensagem chegou ao broker
        rabbitTemplate.setConfirmCallback((correlationData, ack, cause) -> {
            if (ack) {
                log.debug("Mensagem confirmada pelo broker: {}", correlationData.getId());
            } else {
                log.error("Broker recusou mensagem: id={}, causa={}", correlationData.getId(), cause);
                // Implementar reenvio ou alertar
            }
        });

        // Confirma que mensagem foi roteada para alguma fila
        rabbitTemplate.setReturnsCallback(returned -> {
            log.error("Mensagem não roteada para nenhuma fila: exchange={}, routingKey={}, replyText={}",
                returned.getExchange(), returned.getRoutingKey(), returned.getReplyText());
        });
    }

    public void publishOrderCreated(Order order) {
        OrderCreatedEvent event = OrderCreatedEvent.from(order);

        CorrelationData correlationData = new CorrelationData(order.getId().toString());
        MessageProperties props = new MessageProperties();
        props.setCorrelationId(order.getId().toString());
        props.setContentType(MessageProperties.CONTENT_TYPE_JSON);
        props.setDeliveryMode(MessageDeliveryMode.PERSISTENT);  // sobrevive a restart do broker

        Message message = new Message(serialize(event), props);

        rabbitTemplate.convertAndSend(
            RabbitMQConfig.ORDERS_EXCHANGE,
            "orders.created",
            message,
            correlationData
        );

        log.info("Evento publicado: orderId={}", order.getId());
    }
}
```

