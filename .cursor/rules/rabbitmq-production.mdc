# RabbitMQ em Produção — Java/Spring Boot + Spring AMQP

## Configuração Base

```yaml
# application.yml
spring:
  rabbitmq:
    host: ${RABBITMQ_HOST:localhost}
    port: ${RABBITMQ_PORT:5672}
    username: ${RABBITMQ_USER:guest}
    password: ${RABBITMQ_PASS:guest}
    virtual-host: ${RABBITMQ_VHOST:/}
    listener:
      simple:
        acknowledge-mode: manual        # SEMPRE manual em produção
        prefetch: 10                    # quantas mensagens por consumer sem ack
        concurrency: 3                  # consumers mínimos
        max-concurrency: 10             # consumers máximos (auto-scaling)
        retry:
          enabled: false                # desativa retry automático — usamos DLX
        default-requeue-rejected: false # mensagens rejeitadas vão para DLX
    template:
      mandatory: true                   # habilita publisher returns
    publisher-confirm-type: correlated  # publisher confirms
    publisher-returns: true
```

---

## Topologia Completa: Exchange → Queue → DLX → DLQ

```java
@Configuration
public class RabbitMQConfig {

    // ===================== CONSTANTES =====================
    public static final String ORDERS_EXCHANGE = "orders.exchange";
    public static final String ORDERS_QUEUE    = "orders.queue";
    public static final String ORDERS_DLX      = "orders.dlx";           // Dead Letter Exchange
    public static final String ORDERS_DLQ      = "orders.dlq";           // Dead Letter Queue
    public static final String ORDERS_RETRY_EXCHANGE = "orders.retry.exchange";
    public static final String ORDERS_RETRY_QUEUE    = "orders.retry.queue";

    // ===================== EXCHANGES =====================
    @Bean
    public TopicExchange ordersExchange() {
        return ExchangeBuilder.topicExchange(ORDERS_EXCHANGE)
            .durable(true)
            .build();
    }

    @Bean
    public DirectExchange ordersDlx() {
        return ExchangeBuilder.directExchange(ORDERS_DLX)
            .durable(true)
            .build();
    }

    @Bean
    public DirectExchange ordersRetryExchange() {
        return ExchangeBuilder.directExchange(ORDERS_RETRY_EXCHANGE)
            .durable(true)
            .build();
    }

    // ===================== QUEUES =====================
    @Bean
    public Queue ordersQueue() {
        return QueueBuilder.durable(ORDERS_QUEUE)
            .withArgument("x-dead-letter-exchange", ORDERS_DLX)     // onde enviar mensagens rejeitadas
            .withArgument("x-dead-letter-routing-key", ORDERS_DLQ)  // routing key na DLX
            .withArgument("x-message-ttl", 300_000)                  // 5 min TTL (opcional)
            .build();
    }

    @Bean
    public Queue ordersDlq() {
        // DLQ simples — não configura DLX própria para evitar loop infinito
        return QueueBuilder.durable(ORDERS_DLQ)
            .build();
    }

    @Bean
    public Queue ordersRetryQueue() {
        return QueueBuilder.durable(ORDERS_RETRY_QUEUE)
            .withArgument("x-dead-letter-exchange", ORDERS_EXCHANGE)   // volta para fila original após TTL
            .withArgument("x-dead-letter-routing-key", "orders.created")
            .withArgument("x-message-ttl", 30_000)                      // espera 30s antes de retentar
            .build();
    }

    // ===================== BINDINGS =====================
    @Bean
    public Binding ordersBinding() {
        return BindingBuilder.bind(ordersQueue())
            .to(ordersExchange())
            .with("orders.#");  // routing key padrão
    }

    @Bean
    public Binding ordersDlqBinding() {
        return BindingBuilder.bind(ordersDlq())
            .to(ordersDlx())
            .with(ORDERS_DLQ);
    }

    @Bean
    public Binding ordersRetryBinding() {
        return BindingBuilder.bind(ordersRetryQueue())
            .to(ordersRetryExchange())
            .with(ORDERS_RETRY_QUEUE);
    }
}
```

